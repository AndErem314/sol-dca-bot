# Phantom Wallet Configuration
# NEVER SHARE YOUR PRIVATE KEY!
PHANTOM_PRIVATE_KEY=your_private_key_base58_here
PHANTOM_PUBLIC_KEY=your_public_key_here

# Solana Network
RPC_ENDPOINT=https://api.mainnet-beta.solana.com
# Alternative RPCs:
# - https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY
# - https://ssc-dao.genesysgo.net/

# Jupiter API (optional, get from https://station.jup.ag/)
JUPITER_API_KEY=your_api_key_here

# Trading Strategy Parameters
INITIAL_ORDER_USDT=10.0
ORDER_MULTIPLIER=1.10
MAX_SAFETY_ORDERS=30
PRICE_DROP_PERCENT=1.33
TARGET_PROFIT_PERCENT=2.0
MAX_DRAWDOWN_PERCENT=40.0

# Token Addresses (Solana mainnet)
SOL_MINT=So11111111111111111111111111111111111111112
USDT_MINT=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB

# Trading Settings
MAX_SLIPPAGE_PERCENT=1.0
CHECK_INTERVAL_SECONDS=60  # Check price every 60 seconds
MIN_SOL_BALANCE=0.1        # Minimum SOL for transaction fees
MIN_USDT_BALANCE=20.0      # Minimum USDT balance to continue

# Logging
LOG_LEVEL=info
LOG_TO_FILE=true

# Safety Features
ENABLE_EMERGENCY_STOP=true
EMERGENCY_STOP_PERCENT=50.0  # Stop if price drops 50% from entry

# Notification (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id